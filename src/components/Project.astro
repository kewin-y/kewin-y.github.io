---
type Props = {
  project: {
    title: string;
    description: string;
    link?: string;
    tags: string[];
  };
};

const { project } = Astro.props;
const Tag = project.link ? "a" : "div";
---

<Tag
  class:list={[
    "border-neutral-300 border bg-neutral-100 rounded-md p-5 flex flex-col gap-2 hover:bg-neutral-200 transition-all duration-200",
    project.link ? "cursor-pointer" : "cursor-default",
  ]}
  {...project.link
    ? { href: project.link, target: "_blank", rel: "noopener noreferrer" }
    : {}}
>
  <h1 class="font-bold">{project.title}</h1>
  <p>{project.description}</p>
  <ul class="flex flex-wrap gap-2 mt-2">
    {
      project.tags.map((tag) => (
        <li class="rounded-md border border-neutral-300 bg-white/60 px-2.5 py-0.5 text-xs font-medium text-neutral-600">
          {tag}
        </li>
      ))
    }
  </ul>
</Tag>
