---
import Layout from "@/layouts/Layout.astro";
import Link from "@/components/Link.astro";
import Project from "@/components/Project.astro";
import projects from "@/content/projects.json";

const links = {
    Github: "https://github.com/kewin-y",
    LinkedIn: "https://www.linkedin.com/in/kewin-y",
};
---

<Layout title="Kevin Yu">
    <div class="flex flex-col gap-5">
        <p>
            Hello, I'm Kevin. I study math and computer science at the
            University of Toronto.
        </p>
        <p>
            I like using Neovim and NixOS. My favourite programming languages
            are C, C++, and TypeScript, but I want to learn Rust and get better
            at Python.
        </p>
        <p>
            In my free time, I mess around with aquariums and mechanical
            keyboards.
        </p>
        <div>
            Check out my:
            <ul class="inline-flex flex-wrap gap-2">
                {
                    Object.entries(links).map(([key, value]) => (
                        <li>
                            <Link text={key} href={value} />
                        </li>
                    ))
                }
            </ul>
        </div>
        <div>
            <h1 class="text-2xl font-bold border-b pb-5 mb-5">Projects</h1>
            <ul class="flex flex-col gap-5">
                {projects.map((project) => <Project project={project} />)}
            </ul>
        </div>
    </div>
</Layout>
